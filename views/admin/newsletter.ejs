<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bülten Oluştur — EuroPolitika Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" aria-label="Menüyü aç">☰</button>
  <div class="sidebar-overlay"></div>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <a href="/admin" class="sidebar-logo">EURO<span>POLITIKA</span></a>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item">
        <span class="nav-icon">📊</span> Dashboard
      </a>
      <a href="/admin/haberler" class="nav-item">
        <span class="nav-icon">📰</span> Haberler
      </a>
      <a href="/admin/bulten-olustur" class="nav-item active">
        <span class="nav-icon">✉️</span> Bülten Oluştur
      </a>
      <a href="/admin/aboneler" class="nav-item">
        <span class="nav-icon">👥</span> Aboneler
      </a>
      <a href="/" class="nav-item" target="_blank">
        <span class="nav-icon">🌐</span> Siteye Git
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="nav-item logout">
        <span class="nav-icon">🚪</span> Çıkış
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1>Haftalık/Günlük Bülten Oluştur</h1>
    </div>

    <div class="admin-content" style="max-width: 800px;">
      
      <div class="card">
        <div class="card-header">
          <h2>Bülten İçerik Linkleri</h2>
        </div>
        <div class="card-body">
          <p style="color: #718096; font-size: 14px; margin-bottom: 24px; line-height: 1.5;">
            Yatırımcılarınıza ve okuyucularınıza göndermek istediğiniz haber linklerini (makale, kur haberleri, vb.) ekleyin. AI bu haberleri tek bir bülten (digest) şeklinde birleştirecek, görsellerini kaynak sitelerden yerelleştirip indirdikten sonra düzenlemeniz için editöre aktaracaktır.
          </p>

          <form id="newsletterForm" style="display: flex; flex-direction: column; gap: 16px;">
            <div id="linksContainer" style="display: flex; flex-direction: column; gap: 12px;">
              
              <!-- Link Input Slot 1 -->
              <div class="link-input-row" style="display: flex; gap: 8px; align-items: center;">
                <span style="font-weight: 600; color: #718096; font-size: 13px; width: 60px;">Link #1:</span>
                <input type="url" name="urls[]" placeholder="https://example.com/haber-linki" required style="flex: 1; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none;">
                <button type="button" class="btn btn-secondary btn-remove-link" disabled style="padding: 10px 16px; background-color: #E2E8F0; color: #718096; border-color: #E2E8F0; cursor: not-allowed; border-radius: 6px;">✕</button>
              </div>

              <!-- Link Input Slot 2 -->
              <div class="link-input-row" style="display: flex; gap: 8px; align-items: center;">
                <span style="font-weight: 600; color: #718096; font-size: 13px; width: 60px;">Link #2:</span>
                <input type="url" name="urls[]" placeholder="https://example.com/haber-linki" style="flex: 1; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none;">
                <button type="button" class="btn btn-secondary btn-remove-link" style="padding: 10px 16px; border-radius: 6px;">✕</button>
              </div>

            </div>

            <div style="display: flex; gap: 12px; margin-top: 12px;">
              <button type="button" id="btnAddLink" class="btn btn-secondary" style="padding: 10px 20px; font-size: 13px; border-radius: 6px;">
                ➕ Yeni Link Ekle
              </button>
              <button type="submit" id="btnSubmitNewsletter" class="btn btn-primary" style="flex: 1; padding: 12px 24px; font-weight: 600; border-radius: 6px;">
                🤖 AI ile Bülten Derle
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Loading State Panel -->
      <div id="newsletterLoading" class="card" style="display: none; text-align: center; padding: 40px 20px;">
        <div style="font-size: 40px; margin-bottom: 16px; animation: spin 2s linear infinite; display: inline-block;">⚙️</div>
        <h3 style="font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin-bottom: 8px; color: #1A1A1A;">Bülteniniz Derleniyor...</h3>
        <p style="color: #718096; font-size: 13px; max-width: 400px; margin: 0 auto 20px auto; line-height: 1.5;">Haber linkleri kazınıyor, görseller sunucuya indiriliyor ve AI tüm verileri analiz ederek birleştiriyor. Bu işlem 15-30 saniye sürebilir, lütfen bekleyin.</p>
        <div style="width: 100%; height: 6px; background-color: #E2E8F0; border-radius: 3px; overflow: hidden; position: relative;">
          <div style="position: absolute; height: 100%; background-color: #C53030; width: 30%; border-radius: 3px; animation: loadingBar 2s ease-in-out infinite;"></div>
        </div>
      </div>

    </div>
  </main>

  <style>
    @keyframes spin {
      100% { transform: rotate(360deg); }
    }
    @keyframes loadingBar {
      0% { left: -30%; }
      50% { left: 100%; }
      100% { left: 100%; }
    }
  </style>

  <script src="/js/admin.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('linksContainer');
      const btnAddLink = document.getElementById('btnAddLink');
      const form = document.getElementById('newsletterForm');
      const loading = document.getElementById('newsletterLoading');
      const cardForm = form.closest('.card');

      // Update slot numbers & delete buttons state
      const updateLinkSlots = () => {
        const rows = container.querySelectorAll('.link-input-row');
        rows.forEach((row, idx) => {
          row.querySelector('span').textContent = `Link #${idx + 1}:`;
          const removeBtn = row.querySelector('.btn-remove-link');
          if (rows.length === 1) {
            removeBtn.disabled = true;
            removeBtn.style.cursor = 'not-allowed';
          } else {
            removeBtn.disabled = false;
            removeBtn.style.cursor = 'pointer';
          }
        });
      };

      // Add dynamic link input
      btnAddLink.addEventListener('click', () => {
        const rowsCount = container.querySelectorAll('.link-input-row').length;
        if (rowsCount >= 6) {
          alert('Tek seferde en fazla 6 adet haber linki derleyebilirsiniz.');
          return;
        }

        const newRow = document.createElement('div');
        newRow.className = 'link-input-row';
        newRow.style.display = 'flex';
        newRow.style.gap = '8px';
        newRow.style.alignItems = 'center';
        newRow.innerHTML = `
          <span style="font-weight: 600; color: #718096; font-size: 13px; width: 60px;">Link #${rowsCount + 1}:</span>
          <input type="url" name="urls[]" placeholder="https://example.com/haber-linki" style="flex: 1; padding: 10px 14px; border: 1px solid #CBD5E0; border-radius: 6px; font-family: inherit; font-size: 14px; outline: none;">
          <button type="button" class="btn btn-secondary btn-remove-link" style="padding: 10px 16px; border-radius: 6px;">✕</button>
        `;
        container.appendChild(newRow);
        
        // Bind delete
        newRow.querySelector('.btn-remove-link').addEventListener('click', () => {
          newRow.remove();
          updateLinkSlots();
        });

        updateLinkSlots();
      });

      // Bind initial delete button
      container.querySelectorAll('.btn-remove-link').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.target.closest('.link-input-row').remove();
          updateLinkSlots();
        });
      });

      // Form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const inputs = Array.from(form.querySelectorAll('input[name="urls[]"]'));
        const urls = inputs.map(i => i.value.trim()).filter(Boolean);

        if (urls.length === 0) {
          alert('Lütfen en az bir haber linki girin.');
          return;
        }

        // Show loading state
        cardForm.style.display = 'none';
        loading.style.display = 'block';

        try {
          const response = await fetch('/api/ai/process-newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ urls })
          });

          const res = await response.json();
          if (!response.ok || !res.success) {
            throw new Error(res.message || 'Bülten derleme hatası.');
          }

          // Write compiled bülten data to sessionStorage for editor form consumption
          sessionStorage.setItem('newsletter_data', JSON.stringify({
            title: res.data.title,
            excerpt: res.data.excerpt,
            content: res.data.content,
            category: res.data.category,
            tags: res.data.tags,
            cover_image: res.data.cover_image,
            resolvedImages: res.resolvedImages
          }));

          // Redirect to New Article Editor
          window.location.href = '/admin/haberler/yeni';

        } catch (err) {
          alert(`Hata: ${err.message}`);
          cardForm.style.display = 'block';
          loading.style.display = 'none';
        }
      });

    });
  </script>

</body>
</html>
